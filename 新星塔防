import React, { useEffect, useRef, useState, useCallback } from 'react';
import { initializeApp } from 'firebase/app';
import { getFirestore, collection, doc, setDoc } from 'firebase/firestore';
import { getAuth, signInAnonymously } from 'firebase/auth';

const App = () => {
  const canvasRef = useRef(null);
  const containerRef = useRef(null);
  const requestRef = useRef();
  const apiKey = ""; // Provided by environment

  const [cheatCode, setCheatCode] = useState("");
  const [isCheatActive, setIsCheatActive] = useState(false);
  const [aiAdvice, setAiAdvice] = useState("正在扫描战场...");
  const [isGeneratingAdvice, setIsGeneratingAdvice] = useState(false);
  const [isGeneratingSummary, setIsGeneratingSummary] = useState(false);
  const [gameSummary, setGameSummary] = useState("");
  
  const [uiState, setUiState] = useState({
    score: 0,
    ammo: [20, 40, 20],
    gameOver: false,
    win: false,
    started: false,
  });

  const gameStateRef = useRef({
    score: 0,
    gameOver: false,
    win: false,
    missiles: [], 
    explosions: [], 
    enemies: [], 
    cities: [],
    turrets: [],
    lastEnemySpawn: 0,
    spawnRate: 2000, 
    difficultyMultiplier: 1.0,
    isCheatActive: false,
  });

  const EXPLOSION_RADIUS = 38;
  const EXPLOSION_SPEED = 1.4;
  const BASE_MISSILE_SPEED = 7.5;
  const ENEMY_SPEED_BASE = 1.2;
  const WIN_SCORE = 1000;

  // --- Gemini API Integrations ---

  const callGemini = async (prompt, systemPrompt = "") => {
    let retries = 0;
    const delays = [1000, 2000, 4000, 8000, 16000];
    
    while (retries < 5) {
      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            systemInstruction: { parts: [{ text: systemPrompt }] }
          })
        });
        const result = await response.json();
        return result.candidates?.[0]?.content?.parts?.[0]?.text || "分析中断。";
      } catch (e) {
        retries++;
        if (retries === 5) throw e;
        await new Promise(res => setTimeout(res, delays[retries-1]));
      }
    }
  };

  const speakText = async (text) => {
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: `Say in a cool, robotic military voice: ${text}` }] }],
          generationConfig: {
            responseModalities: ["AUDIO"],
            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Puck" } } }
          },
          model: "gemini-2.5-flash-preview-tts"
        })
      });
      const result = await response.json();
      const pcmData = result.candidates[0].content.parts[0].inlineData.data;
      
      const audioBlob = await (await fetch(`data:audio/l16;base64,${pcmData}`)).blob();
      const audioUrl = URL.createObjectURL(audioBlob);
      const audio = new Audio(audioUrl);
      audio.play();
    } catch (e) {
      console.error("TTS Error", e);
    }
  };

  const generateTacticalAdvice = async () => {
    if (isGeneratingAdvice) return;
    setIsGeneratingAdvice(true);
    const state = gameStateRef.current;
    const cityCount = state.cities.filter(c => c.active).length;
    const turretCount = state.turrets.filter(t => t.active).length;
    
    const prompt = `当前分数: ${state.score}。存活城市: ${cityCount}/6。存活炮台: ${turretCount}/3。弹药情况: ${state.turrets.map(t => t.ammo).join('/')}。难度系数: ${state.difficultyMultiplier.toFixed(2)}。请给出一句简短的中文战术指令，不要超过15个字。`;
    const systemPrompt = "你是一位冷酷而专业的AI战场指挥官，负责给防御指挥官提供简短、干练的战术建议。";
    
    const advice = await callGemini(prompt, systemPrompt);
    setAiAdvice(advice);
    setIsGeneratingAdvice(false);
  };

  const generateEndSummary = async () => {
    setIsGeneratingSummary(true);
    const state = gameStateRef.current;
    const cityCount = state.cities.filter(c => c.active).length;
    const prompt = `游戏结束。结果: ${state.win ? "胜利" : "失败"}。最终得分: ${state.score}。存活城市: ${cityCount}。外挂是否激活: ${state.isCheatActive}。请写一段简短的游戏总结评价，包含对玩家表现的分析，风格要像科幻电影中的战后简报。`;
    
    const summary = await callGemini(prompt, "你是一位星际战争分析官。");
    setGameSummary(summary);
    setIsGeneratingSummary(false);
    speakText(summary);
  };

  // --- Core Game Logic ---

  const initGame = useCallback(() => {
    gameStateRef.current = {
      score: 0,
      gameOver: false,
      win: false,
      missiles: [],
      explosions: [],
      enemies: [],
      cities: [
        { id: 1, x: 0.15, active: true },
        { id: 2, x: 0.25, active: true },
        { id: 3, x: 0.4, active: true }, 
        { id: 4, x: 0.6, active: true },
        { id: 5, x: 0.75, active: true },
        { id: 6, x: 0.85, active: true },
      ],
      turrets: [
        { id: 1, x: 0.05, ammo: 20, maxAmmo: 20, active: true },
        { id: 2, x: 0.5, ammo: 40, maxAmmo: 40, active: true },
        { id: 3, x: 0.95, ammo: 20, maxAmmo: 20, active: true },
      ],
      lastEnemySpawn: Date.now(),
      spawnRate: 2000,
      difficultyMultiplier: 1.0,
      isCheatActive: isCheatActive 
    };
    setGameSummary("");
    setAiAdvice("防御网已启动，等待指令。");
    setUiState({
      score: 0,
      ammo: [20, 40, 20],
      gameOver: false,
      win: false,
      started: true,
    });
  }, [isCheatActive]);

  const triggerVictory = useCallback(() => {
    const state = gameStateRef.current;
    if (state.win) return;
    const remainingAmmo = state.turrets.reduce((sum, t) => sum + (t.active ? t.ammo : 0), 0);
    state.score = Math.max(state.score, WIN_SCORE) + (remainingAmmo * 5);
    state.turrets.forEach(t => {
      if (t.active) {
        t.maxAmmo = Math.max(1, t.maxAmmo - 1);
        t.ammo = Math.max(0, t.ammo - 1);
      }
    });
    state.win = true;
    state.enemies = []; // 胜利后清除敌人
    setUiState(prev => ({ 
      ...prev, 
      win: true, 
      score: state.score,
      ammo: state.turrets.map(t => t.ammo)
    }));
    generateEndSummary();
  }, []);

  const handleCheat = (val) => {
    setCheatCode(val);
    // 秘籍 1: 0622 - 无限弹药
    if (val === "0622") {
      gameStateRef.current.isCheatActive = true;
      setIsCheatActive(true);
      setCheatCode("");
      setAiAdvice("✨ 无限能量协议已注入...");
    }
    // 秘籍 2: 2014 - 立即胜利 (新增)
    if (val === "2014") {
      setCheatCode("");
      setAiAdvice("🚨 紧急指令：执行终极防御协议...");
      triggerVictory();
    }
  };

  const spawnEnemy = (width) => {
    const startX = Math.random() * width;
    const targets = [...gameStateRef.current.cities, ...gameStateRef.current.turrets].filter(t => t.active);
    if (targets.length === 0) return;
    const target = targets[Math.floor(Math.random() * targets.length)];
    const targetX = target.x * width;
    gameStateRef.current.enemies.push({
      x: startX,
      y: 0,
      startX: startX,
      startY: 0,
      targetX: targetX,
      targetY: canvasRef.current.height - 40,
      speed: ENEMY_SPEED_BASE * gameStateRef.current.difficultyMultiplier,
    });
  };

  const fireMissile = (targetX, targetY) => {
    const state = gameStateRef.current;
    if (state.gameOver || state.win) return;
    const width = canvasRef.current.width;
    const height = canvasRef.current.height;
    let bestTurret = null;
    let minDist = Infinity;
    state.turrets.forEach((t, index) => {
      if (t.active && (t.ammo > 0 || state.isCheatActive)) {
        const dist = Math.abs(t.x * width - targetX);
        if (dist < minDist) {
          minDist = dist;
          bestTurret = index;
        }
      }
    });
    if (bestTurret !== null) {
      const turret = state.turrets[bestTurret];
      if (!state.isCheatActive) turret.ammo--;
      const speed = state.isCheatActive ? BASE_MISSILE_SPEED * 2 : BASE_MISSILE_SPEED;
      state.missiles.push({
        startX: turret.x * width,
        startY: height - 50,
        x: turret.x * width,
        y: height - 50,
        targetX, targetY,
        progress: 0,
        speed: speed,
        distance: Math.hypot(targetX - turret.x * width, targetY - (height - 50))
      });
      setUiState(prev => ({ ...prev, ammo: state.turrets.map(t => t.ammo) }));
    }
  };

  const update = () => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const state = gameStateRef.current;
    const { width, height } = canvas;
    if (state.gameOver || state.win) return;
    const now = Date.now();
    if (now - state.lastEnemySpawn > state.spawnRate) {
      spawnEnemy(width);
      state.lastEnemySpawn = now;
      state.spawnRate = Math.max(600, state.spawnRate * 0.98); 
      state.difficultyMultiplier += 0.01;
    }
    state.missiles = state.missiles.filter(m => {
      m.progress += m.speed;
      const ratio = Math.min(1, m.progress / m.distance);
      m.x = m.startX + (m.targetX - m.startX) * ratio;
      m.y = m.startY + (m.targetY - m.startY) * ratio;
      if (ratio >= 1) {
        state.explosions.push({ x: m.targetX, y: m.targetY, radius: 0, growing: true });
        return false;
      }
      return true;
    });
    state.explosions = state.explosions.filter(e => {
      if (e.growing) {
        e.radius += EXPLOSION_SPEED;
        if (e.radius >= EXPLOSION_RADIUS) e.growing = false;
      } else {
        e.radius -= EXPLOSION_SPEED * 0.8;
      }
      return e.radius > 0;
    });
    state.enemies = state.enemies.filter(en => {
      const angle = Math.atan2(en.targetY - en.y, en.targetX - en.x);
      en.x += Math.cos(angle) * en.speed;
      en.y += Math.sin(angle) * en.speed;
      let isDestroyed = false;
      state.explosions.forEach(exp => {
        if (Math.hypot(en.x - exp.x, en.y - exp.y) < exp.radius) isDestroyed = true;
      });
      if (isDestroyed) {
        state.score += 20;
        state.explosions.push({ x: en.x, y: en.y, radius: 15, growing: true });
        if (state.score >= WIN_SCORE) {
          triggerVictory();
        } else {
          setUiState(prev => ({ ...prev, score: state.score }));
        }
        return false;
      }
      if (en.y >= height - 45) {
        state.cities.forEach(c => {
          if (c.active && Math.abs(en.x - c.x * width) < 25) c.active = false;
        });
        state.turrets.forEach(t => {
          if (t.active && Math.abs(en.x - t.x * width) < 35) t.active = false;
        });
        state.explosions.push({ x: en.x, y: en.y, radius: 20, growing: true });
        if (state.turrets.every(t => !t.active)) {
          state.gameOver = true;
          setUiState(prev => ({ ...prev, gameOver: true }));
          generateEndSummary();
        }
        return false;
      }
      return true;
    });
  };

  const draw = () => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const state = gameStateRef.current;
    const { width, height } = canvas;
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = '#050510';
    ctx.fillRect(0, 0, width, height);
    ctx.fillStyle = '#ffffff33';
    for(let i=0; i<30; i++) {
        const x = (i * 137.5) % width;
        const y = (i * 250) % height;
        ctx.fillRect(x, y, 1, 1);
    }
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, height - 40, width, 40);
    state.cities.forEach(c => {
      const x = c.x * width;
      if (c.active) {
        ctx.fillStyle = '#4cc9f0';
        ctx.fillRect(x - 12, height - 60, 24, 20);
      } else {
        ctx.fillStyle = '#333344'; 
        ctx.fillRect(x - 10, height - 45, 20, 5);
      }
    });
    state.turrets.forEach(t => {
      const x = t.x * width;
      if (t.active) {
        ctx.fillStyle = state.isCheatActive ? '#ffb703' : '#f72585';
        ctx.beginPath();
        ctx.moveTo(x - 25, height - 40);
        ctx.lineTo(x + 25, height - 40);
        ctx.lineTo(x + 15, height - 65);
        ctx.lineTo(x - 15, height - 65);
        ctx.closePath();
        ctx.fill();
        ctx.fillStyle = '#fff';
        ctx.font = '10px Arial';
        ctx.textAlign = 'center';
        ctx.fillText(state.isCheatActive ? "∞" : t.ammo, x, height - 45);
      }
    });
    
    state.missiles.forEach(m => {
      ctx.setLineDash([2, 4]);
      ctx.strokeStyle = state.isCheatActive ? '#ffb70344' : '#ffffff44';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(m.startX, m.startY);
      ctx.lineTo(m.x, m.y);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.strokeStyle = state.isCheatActive ? '#ffb703' : '#f72585';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(m.targetX, m.targetY, 3, 0, Math.PI * 2);
      ctx.stroke();

      const missileColor = state.isCheatActive ? '#ffb703' : '#ffffff';
      const missileGlow = ctx.createRadialGradient(m.x, m.y, 0, m.x, m.y, 6);
      missileGlow.addColorStop(0, missileColor);
      missileGlow.addColorStop(1, 'rgba(0,0,0,0)');
      
      ctx.fillStyle = missileGlow;
      ctx.beginPath();
      ctx.arc(m.x, m.y, 6, 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = missileColor;
      ctx.beginPath();
      ctx.arc(m.x, m.y, 2.5, 0, Math.PI * 2);
      ctx.fill();
    });

    state.enemies.forEach(en => {
      ctx.strokeStyle = '#ff4d6d';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(en.x, en.y);
      const angle = Math.atan2(en.targetY - en.y, en.targetX - en.x);
      ctx.lineTo(en.x - Math.cos(angle) * 15, en.y - Math.sin(angle) * 15);
      ctx.stroke();
    });

    state.explosions.forEach(e => {
      const grad = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.radius);
      grad.addColorStop(0, '#fff');
      grad.addColorStop(0.5, '#f15bb5');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(e.x, e.y, e.radius, 0, Math.PI * 2);
      ctx.fill();
    });
  };

  const gameLoop = useCallback(() => {
    update();
    draw();
    requestRef.current = requestAnimationFrame(gameLoop);
  }, []);

  useEffect(() => {
    const handleResize = () => {
      if (canvasRef.current && containerRef.current) {
        canvasRef.current.width = containerRef.current.clientWidth;
        canvasRef.current.height = containerRef.current.clientHeight;
      }
    };
    window.addEventListener('resize', handleResize);
    handleResize();
    requestRef.current = requestAnimationFrame(gameLoop);
    return () => {
      window.removeEventListener('resize', handleResize);
      cancelAnimationFrame(requestRef.current);
    };
  }, [gameLoop]);

  const handleInteraction = (e) => {
    if (!uiState.started || uiState.gameOver || uiState.win) return;
    const rect = canvasRef.current.getBoundingClientRect();
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    if (clientX !== undefined && clientY !== undefined) {
      const x = clientX - rect.left;
      const y = clientY - rect.top;
      fireMissile(x, y);
    }
  };

  return (
    <div className="flex flex-col h-screen w-screen bg-[#050510] text-white font-sans overflow-hidden select-none fixed inset-0">
      {/* Header Overlay */}
      <header className="absolute top-0 left-0 right-0 flex justify-between items-start px-6 py-4 bg-gradient-to-b from-slate-900/90 to-transparent z-10 pointer-events-none">
        <div className="flex flex-col pointer-events-auto">
          <h1 className="text-xl font-black italic tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-blue-400">
            HOMER <span className="text-white not-italic">NOVA DEFENSE</span>
          </h1>
          <div className="flex items-center gap-2 mt-1">
            <button 
              onClick={generateTacticalAdvice}
              disabled={isGeneratingAdvice}
              className="text-[9px] px-2 py-0.5 bg-blue-600/30 border border-blue-500/50 rounded hover:bg-blue-600/50 transition-all flex items-center gap-1"
            >
              ✨ {isGeneratingAdvice ? 'AI 正在分析...' : 'AI 战术情报'}
            </button>
            <span className="text-[10px] text-blue-300 italic opacity-80">{aiAdvice}</span>
          </div>
        </div>
        <div className="text-right pointer-events-auto">
          <div className="text-[10px] uppercase opacity-50 tracking-widest">Score</div>
          <div className="text-3xl font-mono font-bold text-yellow-400 leading-none drop-shadow-[0_0_8px_rgba(250,204,21,0.5)]">
            {uiState.score.toLocaleString().padStart(5, '0')}
          </div>
        </div>
      </header>

      {/* Fullscreen Game Stage */}
      <main ref={containerRef} className="relative w-full h-full touch-none overflow-hidden">
        <canvas
          ref={canvasRef}
          onMouseDown={handleInteraction}
          onTouchStart={(e) => { e.preventDefault(); handleInteraction(e); }}
          className="block w-full h-full cursor-crosshair"
        />

        {/* Start Overlay */}
        {!uiState.started && (
          <div className="absolute inset-0 flex flex-col items-center justify-center bg-slate-950/90 backdrop-blur-md z-30 p-8 text-center">
            <h2 className="text-6xl font-black mb-6 tracking-tight uppercase italic text-transparent bg-clip-text bg-gradient-to-br from-white to-slate-500">Protect The Core</h2>
            <button onClick={initGame} className="px-16 py-5 bg-white text-black rounded-full font-black text-xl shadow-[0_0_30px_rgba(255,255,255,0.3)] active:scale-95 transition-all hover:bg-blue-50">
              INITIALIZE MISSION / 开始任务
            </button>
          </div>
        )}

        {/* End Overlay */}
        {(uiState.gameOver || uiState.win) && (
          <div className="absolute inset-0 flex flex-col items-center justify-center bg-slate-950/95 z-40 p-10 animate-in fade-in zoom-in overflow-y-auto">
            <div className={`text-7xl font-black mb-6 italic tracking-tighter ${uiState.win ? 'text-blue-400 drop-shadow-[0_0_15px_rgba(96,165,250,0.5)]' : 'text-pink-600 drop-shadow-[0_0_15px_rgba(219,39,119,0.5)]'}`}>
              {uiState.win ? 'MISSION CLEAR' : 'MISSION FAILED'}
            </div>
            
            <div className="max-w-lg w-full bg-slate-900/80 border border-slate-700/50 backdrop-blur-xl rounded-2xl p-8 mb-8 text-center shadow-2xl">
                <div className="text-xs uppercase text-blue-400 font-bold tracking-widest mb-4 flex items-center justify-center gap-2">
                    ✨ Gemini 战事评估
                    {isGeneratingSummary && <div className="w-2 h-2 bg-blue-400 rounded-full animate-ping"></div>}
                </div>
                <p className="text-base text-slate-300 leading-relaxed italic font-light">
                    {gameSummary || "正在整理战后数据并生成简报..."}
                </p>
                {gameSummary && (
                  <button onClick={() => speakText(gameSummary)} className="mt-6 flex items-center gap-2 mx-auto text-xs text-blue-400 hover:text-blue-300 transition-colors">
                    <span className="p-2 bg-blue-500/10 rounded-full">🔊</span> 重播语音简报
                  </button>
                )}
            </div>

            <div className="text-3xl font-mono text-yellow-400 mb-8 tracking-widest uppercase">FINAL SCORE: {uiState.score}</div>
            <button onClick={initGame} className="px-16 py-6 bg-blue-600 rounded-2xl text-2xl font-black hover:bg-blue-500 transition-all shadow-[0_10px_40px_rgba(37,99,235,0.4)] active:scale-95">
              REBOOT / 再玩一次
            </button>
          </div>
        )}

        {/* Cheat Indicator */}
        {isCheatActive && (
          <div className="absolute top-24 left-1/2 -translate-x-1/2 px-6 py-2 bg-yellow-500/20 border border-yellow-500/50 backdrop-blur-sm rounded-full text-yellow-400 text-[11px] font-black tracking-[0.3em] animate-pulse z-20 shadow-[0_0_20px_rgba(234,179,8,0.2)]">
            ✨ RAGE MODE ACTIVE: UNLIMITED AMMO + SPEED BOOST
          </div>
        )}
      </main>

      {/* Floating Control UI */}
      <footer className="absolute bottom-6 left-0 right-0 px-6 pointer-events-none z-10">
        <div className="flex justify-center items-end gap-4 max-w-4xl mx-auto pointer-events-auto">
          {uiState.ammo.map((count, i) => (
            <div key={i} className={`flex flex-col items-center justify-center px-6 py-3 rounded-2xl backdrop-blur-md transition-all border ${isCheatActive ? 'bg-yellow-500/10 border-yellow-500/50 shadow-[0_0_15px_rgba(234,179,8,0.2)]' : (count > 0 ? 'bg-black/40 border-white/10' : 'bg-red-900/20 border-red-500/30')}`}>
              <div className={`text-[9px] font-black uppercase mb-1 tracking-widest ${isCheatActive ? 'text-yellow-500' : 'opacity-40'}`}>{['Left', 'Main', 'Right'][i]}</div>
              <div className={`font-mono font-black text-2xl ${isCheatActive ? 'text-yellow-400' : (count === 0 ? 'text-red-500' : 'text-white')}`}>
                {isCheatActive ? "∞" : count}
              </div>
            </div>
          ))}
        </div>
        
        {/* Hidden Input for Cheat Code */}
        <div className="absolute bottom-2 left-4 opacity-5 hover:opacity-100 transition-opacity pointer-events-auto">
          <input 
            type="password" 
            placeholder="SYSTEM ACCESS..." 
            className="bg-transparent border border-white/20 text-[8px] p-1 w-20 rounded outline-none focus:border-yellow-500 text-white"
            value={cheatCode}
            onChange={(e) => handleCheat(e.target.value)}
          />
        </div>
      </footer>
    </div>
  );
};

export default App;
